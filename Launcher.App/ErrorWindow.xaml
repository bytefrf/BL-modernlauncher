<Window x:Class="Launcher.App.ErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ошибка лаунчера"
        Icon="/Sprite-0001.png"
        Width="800"
        Height="580"
        MinWidth="740"
        MinHeight="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#08110F" />
        <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#F207100E" />
        <SolidColorBrush x:Key="TitleBarBorderBrush" Color="#20372E" />
        <SolidColorBrush x:Key="WindowIconBackgroundBrush" Color="#2B1514" />
        <SolidColorBrush x:Key="WindowIconBorderBrush" Color="#A95B54" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111C19" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#172620" />
        <SolidColorBrush x:Key="CardBrush" Color="#D9111C19" />
        <SolidColorBrush x:Key="CardAltBrush" Color="#CC111C19" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#315245" />
        <SolidColorBrush x:Key="MutedBrush" Color="#B6C8BD" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7F1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#D7A84D" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#B9802A" />
        <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#E008110F" />
        <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#263B33" />
        <SolidColorBrush x:Key="SoftButtonBackgroundBrush" Color="#243B32" />
        <SolidColorBrush x:Key="SoftButtonBorderBrush" Color="#395F4F" />
        <SolidColorBrush x:Key="SoftButtonHoverBrush" Color="#2F4D41" />
        <SolidColorBrush x:Key="SoftButtonPressedBrush" Color="#1D3129" />
        <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#263B33" />
        <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#182821" />
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#F0C76C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D96B5F" />
        <SolidColorBrush x:Key="TechnicalTextBrush" Color="#D7E2D9" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TitleBarButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SoftButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SoftButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="15"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SoftButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SoftButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SoftButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}" />
            <Setter Property="Foreground" Value="#1A1307" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBackgroundBrush}"
                BorderBrush="{DynamicResource TitleBarBorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="14,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="24" Height="24" CornerRadius="6" Background="{DynamicResource WindowIconBackgroundBrush}" BorderBrush="{DynamicResource WindowIconBorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Text="!" />
                </Border>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="Ошибка лаунчера" />
                <Button Grid.Column="3" Style="{StaticResource TitleBarButton}" Click="CloseButton_Click" Content="X" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border CornerRadius="24" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" Padding="22">
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
                    <TextBlock x:Name="SummaryTextBlock" Margin="0,10,0,0" Foreground="{DynamicResource MutedBrush}" FontSize="14" TextWrapping="Wrap" />
                    <TextBlock x:Name="LogPathTextBlock" Margin="0,12,0,0" Foreground="{DynamicResource AccentBrush}" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border CornerRadius="20" Background="{DynamicResource CardAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock FontSize="17" FontWeight="SemiBold" Text="Что сделать" />
                            <ItemsControl x:Name="ActionsItemsControl" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" Text="*" />
                                            <TextBlock Grid.Column="1" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Expander Header="Технические детали" Foreground="{DynamicResource MutedBrush}">
                        <Border Margin="0,10,0,0" CornerRadius="16" Background="{DynamicResource TextBoxBackgroundBrush}" BorderBrush="{DynamicResource TextBoxBorderBrush}" BorderThickness="1" Padding="14">
                            <TextBox x:Name="TechnicalTextBox"
                                     Height="150"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TechnicalTextBrush}"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" />
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SupportStatusTextBlock"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <Button x:Name="SendLogButton" Grid.Column="1" Width="150" Style="{StaticResource SoftButton}" Click="SendLogButton_Click" Content="Отправить лог" />
                <Button Grid.Column="3" Width="140" Style="{StaticResource SoftButton}" Click="CopyButton_Click" Content="Скопировать" />
                <Button x:Name="OpenLogsButton" Grid.Column="5" Width="130" Style="{StaticResource SoftButton}" Click="OpenLogsButton_Click" Content="Открыть логи" />
                <Button Grid.Column="7" Width="110" Style="{StaticResource PrimaryButton}" Click="CloseButton_Click" Content="Понятно" />
            </Grid>
        </Grid>
    </Grid>
</Window>
